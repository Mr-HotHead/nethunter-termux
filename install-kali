#!/data/data/com.termux/files/usr/bin/bash -e
#
# install-kali — Kali Linux installer for proot-distro (Termux)
#
# Usage:
#   ./install-kali              # Download nano rootfs from Kali servers
#   ./install-kali --local      # Use existing ~/kali-arm64 rootfs
#   ./install-kali --full       # Download full rootfs
#   ./install-kali --minimal    # Download minimal rootfs
#   ./install-kali --nano       # Download nano rootfs (default)
#   ./install-kali --remove     # Remove Kali from proot-distro
#

VERSION="1.0.0"
KALI_ALIAS="kali"

# proot-distro paths
PREFIX="/data/data/com.termux/files/usr"
PLUGIN_DIR="${PREFIX}/etc/proot-distro"
ROOTFS_DIR="${PREFIX}/var/lib/proot-distro/installed-rootfs"
DLCACHE_DIR="${PREFIX}/var/lib/proot-distro/dlcache"

# NetHunter rootfs source
BASE_URL="https://kali.download/nethunter-images/current/rootfs"

# Colors
red='\033[1;31m'
green='\033[1;32m'
yellow='\033[1;33m'
blue='\033[1;34m'
cyan='\033[1;96m'
reset='\033[0m'

msg()  { printf "${blue}[*]${reset} %s\n" "$1"; }
ok()   { printf "${green}[✓]${reset} %s\n" "$1"; }
warn() { printf "${yellow}[!]${reset} %s\n" "$1"; }
err()  { printf "${red}[✗]${reset} %s\n" "$1"; exit 1; }

print_banner() {
    printf "${blue}"
    cat << 'EOF'
 ╔═══════════════════════════════════════╗
 ║  Kali Linux → proot-distro installer ║
 ║  Lean & clean, no bloat              ║
 ╚═══════════════════════════════════════╝
EOF
    printf "${reset}\n"
}

get_arch() {
    case $(getprop ro.product.cpu.abi 2>/dev/null || uname -m) in
        arm64-v8a|aarch64) SYS_ARCH="arm64" ;;
        armeabi*|armv7*)   SYS_ARCH="armhf" ;;
        *)                 err "Unsupported architecture" ;;
    esac
    msg "Architecture: ${SYS_ARCH}"
}

check_deps() {
    msg "Checking dependencies..."
    for pkg in proot proot-distro tar; do
        if ! command -v "$pkg" &>/dev/null; then
            warn "Installing ${pkg}..."
            apt install -y "$pkg" &>/dev/null || err "Failed to install ${pkg}"
        fi
    done
    # xz-utils for .tar.xz extraction
    if ! command -v xz &>/dev/null; then
        warn "Installing xz-utils..."
        apt install -y xz-utils &>/dev/null || err "Failed to install xz-utils"
    fi
    ok "Dependencies OK"
}

create_plugin() {
    local image_variant="${1:-nano}"
    local image_name="kali-nethunter-rootfs-${image_variant}-${SYS_ARCH}.tar.xz"
    local tarball_url="${BASE_URL}/${image_name}"

    msg "Creating proot-distro plugin..."

    cat > "${PLUGIN_DIR}/${KALI_ALIAS}.sh" << PLUGIN
# Kali Linux plugin for proot-distro
# Generated by install-kali v${VERSION}
DISTRO_NAME="Kali Linux"
DISTRO_COMMENT="Kali Rolling (NetHunter ${image_variant}, ${SYS_ARCH})"

TARBALL_STRIP_OPT=0
TARBALL_URL['aarch64']="${BASE_URL}/kali-nethunter-rootfs-${image_variant}-arm64.tar.xz"
TARBALL_SHA256['aarch64']=""
TARBALL_URL['arm']="${BASE_URL}/kali-nethunter-rootfs-${image_variant}-armhf.tar.xz"
TARBALL_SHA256['arm']=""

distro_setup() {
    # Fix profile
    if [ -f ./root/.bash_profile ]; then
        sed -i '/if/,/fi/d' ./root/.bash_profile
    fi

    # Fix sudo
    chmod +s ./usr/bin/sudo 2>/dev/null || true
    chmod +s ./usr/bin/su 2>/dev/null || true
    echo "kali    ALL=(ALL:ALL) ALL" > ./etc/sudoers.d/kali 2>/dev/null || true
    echo "Set disable_coredump false" > ./etc/sudo.conf 2>/dev/null || true

    # Set DNS
    echo "nameserver 8.8.8.8" > ./etc/resolv.conf
    echo "nameserver 8.8.4.4" >> ./etc/resolv.conf

    # Create kex launcher
    mkdir -p ./usr/bin
    cat > ./usr/bin/kex << 'KEXEOF'
#!/bin/bash
case "\$1" in
    start)
        [ ! -f ~/.vnc/passwd ] && vncpasswd
        USR=\$(whoami); SCREEN=":1"
        [ "\$USR" = "root" ] && SCREEN=":2"
        export USER="\$USR"
        vncserver "\$SCREEN" -localhost no
        ;;
    stop)    vncserver -kill :1 2>/dev/null; vncserver -kill :2 2>/dev/null ;;
    status)  vncserver -list ;;
    passwd)  vncpasswd ;;
    *)       echo "Usage: kex {start|stop|status|passwd}" ;;
esac
KEXEOF
    chmod 755 ./usr/bin/kex
}
PLUGIN

    ok "Plugin created: ${PLUGIN_DIR}/${KALI_ALIAS}.sh"
}

install_local() {
    local src="${HOME}/kali-arm64"

    if [ ! -d "$src" ]; then
        err "Local rootfs not found at ${src}"
    fi

    if [ -d "${ROOTFS_DIR}/${KALI_ALIAS}" ]; then
        warn "Kali already installed in proot-distro"
        printf "${cyan}[?] Remove and reinstall? [y/N] ${reset}"
        read -r reply
        if [[ "$reply" =~ ^[Yy] ]]; then
            msg "Removing old installation..."
            chmod -R u+rwx "${ROOTFS_DIR}/${KALI_ALIAS}" 2>/dev/null || true
            rm -rf "${ROOTFS_DIR}/${KALI_ALIAS}"
        else
            err "Aborted"
        fi
    fi

    msg "Moving rootfs from ~/kali-arm64 to proot-distro..."
    mkdir -p "${ROOTFS_DIR}"

    # Move instead of copy — saves space
    mv "$src" "${ROOTFS_DIR}/${KALI_ALIAS}"

    # Ensure .l2s directory exists (proot link2symlink metadata)
    mkdir -p "${ROOTFS_DIR}/${KALI_ALIAS}/.l2s"

    ok "Rootfs moved to proot-distro"

    # Create symlink back for compatibility
    ln -sf "${ROOTFS_DIR}/${KALI_ALIAS}" "$src"
    msg "Symlink: ~/kali-arm64 → ${ROOTFS_DIR}/${KALI_ALIAS}"
}

install_download() {
    local image_variant="${1:-nano}"

    if [ -d "${ROOTFS_DIR}/${KALI_ALIAS}" ]; then
        warn "Kali already installed in proot-distro"
        printf "${cyan}[?] Remove and reinstall? [y/N] ${reset}"
        read -r reply
        if [[ "$reply" =~ ^[Yy] ]]; then
            proot-distro remove "${KALI_ALIAS}" 2>/dev/null || {
                chmod -R u+rwx "${ROOTFS_DIR}/${KALI_ALIAS}" 2>/dev/null || true
                rm -rf "${ROOTFS_DIR}/${KALI_ALIAS}"
            }
        else
            err "Aborted"
        fi
    fi

    msg "Installing Kali via proot-distro (${image_variant})..."
    # proot-distro will use our plugin to download and extract
    proot-distro install "${KALI_ALIAS}"

    ok "Kali installed via proot-distro"
}

create_shortcuts() {
    msg "Creating shortcuts..."

    # nh shortcut — runs kali as user
    cat > "${PREFIX}/bin/nh" << 'NHEOF'
#!/data/data/com.termux/files/usr/bin/bash
exec proot-distro login kali -- "$@"
NHEOF
    chmod 755 "${PREFIX}/bin/nh"

    # nh-root shortcut — runs kali as root (default for proot-distro)
    cat > "${PREFIX}/bin/nh-root" << 'NHREOF'
#!/data/data/com.termux/files/usr/bin/bash
exec proot-distro login kali --user root -- "$@"
NHREOF
    chmod 755 "${PREFIX}/bin/nh-root"

    ok "Shortcuts: 'nh' (login), 'nh-root' (root login)"
}

do_remove() {
    msg "Removing Kali from proot-distro..."

    if [ -d "${ROOTFS_DIR}/${KALI_ALIAS}" ]; then
        proot-distro remove "${KALI_ALIAS}" 2>/dev/null || {
            chmod -R u+rwx "${ROOTFS_DIR}/${KALI_ALIAS}" 2>/dev/null || true
            rm -rf "${ROOTFS_DIR}/${KALI_ALIAS}"
        }
    fi

    rm -f "${PLUGIN_DIR}/${KALI_ALIAS}.sh"
    rm -f "${PREFIX}/bin/nh" "${PREFIX}/bin/nh-root"

    # Remove symlink if exists
    [ -L "${HOME}/kali-arm64" ] && rm -f "${HOME}/kali-arm64"

    ok "Kali removed"
}

print_usage() {
    msg "Usage:"
    printf "  proot-distro login kali          # Login as root\n"
    printf "  proot-distro login kali --user kali  # Login as kali user\n"
    printf "  nh                               # Quick login\n"
    printf "  nh-root                          # Quick root login\n"
    printf "  proot-distro remove kali         # Uninstall\n"
}

# ─── Main ───────────────────────────────────────────────────────────────

print_banner
get_arch

MODE="download"
VARIANT="nano"

while [ $# -gt 0 ]; do
    case "$1" in
        --local)   MODE="local" ;;
        --full)    VARIANT="full" ;;
        --minimal) VARIANT="minimal" ;;
        --nano)    VARIANT="nano" ;;
        --remove)  MODE="remove" ;;
        -h|--help)
            echo "Usage: install-kali [--local|--full|--minimal|--nano|--remove]"
            exit 0
            ;;
        *) err "Unknown option: $1" ;;
    esac
    shift
done

case "$MODE" in
    remove)
        do_remove
        exit 0
        ;;
    local)
        check_deps
        create_plugin "$VARIANT"
        install_local
        create_shortcuts
        ;;
    download)
        check_deps
        create_plugin "$VARIANT"
        install_download "$VARIANT"
        create_shortcuts
        ;;
esac

printf "\n"
ok "Kali Linux ready!"
printf "\n"
print_usage
printf "\n"
