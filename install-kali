#!/data/data/com.termux/files/usr/bin/bash -e
#
# install-kali — Kali Linux installer for proot-distro (Termux)
#
# Usage:
#   ./install-kali              # Download nano rootfs from Kali servers
#   ./install-kali --local      # Use existing ~/kali-arm64 rootfs
#   ./install-kali --full       # Download full rootfs
#   ./install-kali --minimal    # Download minimal rootfs
#   ./install-kali --nano       # Download nano rootfs (default)
#   ./install-kali --remove     # Remove Kali from proot-distro
#

VERSION="1.0.0"
KALI_ALIAS="kali"

# proot-distro paths
PREFIX="/data/data/com.termux/files/usr"
PLUGIN_DIR="${PREFIX}/etc/proot-distro"
ROOTFS_DIR="${PREFIX}/var/lib/proot-distro/installed-rootfs"
DLCACHE_DIR="${PREFIX}/var/lib/proot-distro/dlcache"

# NetHunter rootfs source
BASE_URL="https://kali.download/nethunter-images/current/rootfs"

# Colors
red='\033[1;31m'
green='\033[1;32m'
yellow='\033[1;33m'
blue='\033[1;34m'
cyan='\033[1;96m'
reset='\033[0m'

msg()  { printf "${blue}[*]${reset} %s\n" "$1"; }
ok()   { printf "${green}[✓]${reset} %s\n" "$1"; }
warn() { printf "${yellow}[!]${reset} %s\n" "$1"; }
err()  { printf "${red}[✗]${reset} %s\n" "$1"; exit 1; }

print_banner() {
    printf "${blue}"
    cat << 'EOF'
 ╔═══════════════════════════════════════╗
 ║  Kali Linux → proot-distro installer ║
 ║  Lean & clean, no bloat              ║
 ╚═══════════════════════════════════════╝
EOF
    printf "${reset}\n"
}

get_arch() {
    case $(getprop ro.product.cpu.abi 2>/dev/null || uname -m) in
        arm64-v8a|aarch64) SYS_ARCH="arm64" ;;
        armeabi*|armv7*)   SYS_ARCH="armhf" ;;
        *)                 err "Unsupported architecture" ;;
    esac
    msg "Architecture: ${SYS_ARCH}"
}

check_deps() {
    msg "Checking dependencies..."
    for pkg in proot proot-distro tar; do
        if ! command -v "$pkg" &>/dev/null; then
            warn "Installing ${pkg}..."
            apt install -y "$pkg" &>/dev/null || err "Failed to install ${pkg}"
        fi
    done
    # xz-utils for .tar.xz extraction
    if ! command -v xz &>/dev/null; then
        warn "Installing xz-utils..."
        apt install -y xz-utils &>/dev/null || err "Failed to install xz-utils"
    fi
    ok "Dependencies OK"
}

create_plugin() {
    local image_variant="${1:-nano}"
    local image_name="kali-nethunter-rootfs-${image_variant}-${SYS_ARCH}.tar.xz"
    local tarball_url="${BASE_URL}/${image_name}"

    msg "Creating proot-distro plugin..."

    cat > "${PLUGIN_DIR}/${KALI_ALIAS}.sh" << PLUGIN
# Kali Linux plugin for proot-distro
# Generated by install-kali v${VERSION}
DISTRO_NAME="Kali Linux"
DISTRO_COMMENT="Kali Rolling (NetHunter ${image_variant}, ${SYS_ARCH})"

TARBALL_STRIP_OPT=0
TARBALL_URL['aarch64']="${BASE_URL}/kali-nethunter-rootfs-${image_variant}-arm64.tar.xz"
TARBALL_SHA256['aarch64']=""
TARBALL_URL['arm']="${BASE_URL}/kali-nethunter-rootfs-${image_variant}-armhf.tar.xz"
TARBALL_SHA256['arm']=""

distro_setup() {
    # Fix profile
    if [ -f ./root/.bash_profile ]; then
        sed -i '/if/,/fi/d' ./root/.bash_profile
    fi

    # Fix sudo
    chmod +s ./usr/bin/sudo 2>/dev/null || true
    chmod +s ./usr/bin/su 2>/dev/null || true
    echo "kali    ALL=(ALL:ALL) ALL" > ./etc/sudoers.d/kali 2>/dev/null || true
    echo "Set disable_coredump false" > ./etc/sudo.conf 2>/dev/null || true

    # Set DNS (Google DNS — reliable in proot)
    printf "nameserver 8.8.8.8\nnameserver 8.8.4.4\n" > ./etc/resolv.conf

    # Fix apt sources — use direct HTTPS mirror (http redirector breaks in proot)
    cat > ./etc/apt/sources.list << 'SRCEOF'
deb https://kali.download/kali kali-rolling main contrib non-free non-free-firmware
SRCEOF

    # Suppress login banner for cleaner tool wrapper output
    touch ./root/.hushlogin
    mkdir -p ./home/kali && touch ./home/kali/.hushlogin

    # Create kex launcher
    mkdir -p ./usr/bin
    cat > ./usr/bin/kex << 'KEXEOF'
#!/bin/bash
case "\$1" in
    start)
        [ ! -f ~/.vnc/passwd ] && vncpasswd
        USR=\$(whoami); SCREEN=":1"
        [ "\$USR" = "root" ] && SCREEN=":2"
        export USER="\$USR"
        vncserver "\$SCREEN" -localhost no
        ;;
    stop)    vncserver -kill :1 2>/dev/null; vncserver -kill :2 2>/dev/null ;;
    status)  vncserver -list ;;
    passwd)  vncpasswd ;;
    *)       echo "Usage: kex {start|stop|status|passwd}" ;;
esac
KEXEOF
    chmod 755 ./usr/bin/kex
}
PLUGIN

    ok "Plugin created: ${PLUGIN_DIR}/${KALI_ALIAS}.sh"
}

install_local() {
    local src="${HOME}/kali-arm64"

    if [ ! -d "$src" ]; then
        err "Local rootfs not found at ${src}"
    fi

    if [ -d "${ROOTFS_DIR}/${KALI_ALIAS}" ]; then
        warn "Kali already installed in proot-distro"
        printf "${cyan}[?] Remove and reinstall? [y/N] ${reset}"
        read -r reply
        if [[ "$reply" =~ ^[Yy] ]]; then
            msg "Removing old installation..."
            chmod -R u+rwx "${ROOTFS_DIR}/${KALI_ALIAS}" 2>/dev/null || true
            rm -rf "${ROOTFS_DIR}/${KALI_ALIAS}"
        else
            err "Aborted"
        fi
    fi

    msg "Moving rootfs from ~/kali-arm64 to proot-distro..."
    mkdir -p "${ROOTFS_DIR}"

    # Move instead of copy — saves space
    mv "$src" "${ROOTFS_DIR}/${KALI_ALIAS}"

    # Ensure .l2s directory exists (proot link2symlink metadata)
    mkdir -p "${ROOTFS_DIR}/${KALI_ALIAS}/.l2s"

    ok "Rootfs moved to proot-distro"

    # Apply fixes to existing rootfs (DNS, apt sources, hushlogin)
    local rf="${ROOTFS_DIR}/${KALI_ALIAS}"
    printf "nameserver 8.8.8.8\nnameserver 8.8.4.4\n" > "$rf/etc/resolv.conf"
    cat > "$rf/etc/apt/sources.list" << 'SRCEOF'
deb https://kali.download/kali kali-rolling main contrib non-free non-free-firmware
SRCEOF
    touch "$rf/root/.hushlogin"
    mkdir -p "$rf/home/kali" && touch "$rf/home/kali/.hushlogin"
    # Fix sudo
    chmod +s "$rf/usr/bin/sudo" 2>/dev/null || true
    chmod +s "$rf/usr/bin/su" 2>/dev/null || true
    echo "kali    ALL=(ALL:ALL) ALL" > "$rf/etc/sudoers.d/kali" 2>/dev/null || true
    ok "Applied fixes (DNS, apt sources, sudo)"

    # Create symlink back for compatibility
    ln -sf "${ROOTFS_DIR}/${KALI_ALIAS}" "$src"
    msg "Symlink: ~/kali-arm64 → ${ROOTFS_DIR}/${KALI_ALIAS}"
}

install_download() {
    local image_variant="${1:-nano}"

    if [ -d "${ROOTFS_DIR}/${KALI_ALIAS}" ]; then
        warn "Kali already installed in proot-distro"
        printf "${cyan}[?] Remove and reinstall? [y/N] ${reset}"
        read -r reply
        if [[ "$reply" =~ ^[Yy] ]]; then
            proot-distro remove "${KALI_ALIAS}" 2>/dev/null || {
                chmod -R u+rwx "${ROOTFS_DIR}/${KALI_ALIAS}" 2>/dev/null || true
                rm -rf "${ROOTFS_DIR}/${KALI_ALIAS}"
            }
        else
            err "Aborted"
        fi
    fi

    msg "Installing Kali via proot-distro (${image_variant})..."
    # proot-distro will use our plugin to download and extract
    proot-distro install "${KALI_ALIAS}"

    ok "Kali installed via proot-distro"
}

create_shortcuts() {
    msg "Creating shortcuts..."

    # nethunter — main launcher (compatible with original flags)
    cat > "${PREFIX}/bin/nethunter" << 'NHEOF'
#!/data/data/com.termux/files/usr/bin/bash
# Kali NetHunter launcher via proot-distro
# Usage:
#   nethunter           — login as user kali
#   nethunter -r        — login as root
#   nethunter <cmd>     — run command as kali
#   nethunter -r <cmd>  — run command as root
#   nethunter kex ...   — KeX VNC commands

USER_LOGIN="--user kali"

# Handle -r / -R flag for root
if [[ "${1-}" == "-r" || "${1-}" == "-R" ]]; then
    USER_LOGIN="--user root"
    shift
fi

if [ $# -eq 0 ]; then
    exec proot-distro login kali $USER_LOGIN
else
    exec proot-distro login kali $USER_LOGIN -- "$@"
fi
NHEOF
    chmod 755 "${PREFIX}/bin/nethunter"

    # nh — shortcut for nethunter
    ln -sf "${PREFIX}/bin/nethunter" "${PREFIX}/bin/nh"

    ok "Shortcuts: 'nethunter' / 'nh' (login as kali), 'nethunter -r' (root)"
}

create_tool_wrappers() {
    msg "Creating tool wrappers (Kali binaries → Termux)..."

    local rootfs="${ROOTFS_DIR}/${KALI_ALIAS}"
    local wrapper_dir="${PREFIX}/bin"
    local manifest="${rootfs}/.kali-wrappers"
    local count=0

    # Clean previous wrappers
    if [ -f "$manifest" ]; then
        while IFS= read -r old_wrapper; do
            rm -f "${wrapper_dir}/${old_wrapper}" 2>/dev/null
        done < "$manifest"
        rm -f "$manifest"
    fi

    # Scan Kali-specific packages for binaries
    local kali_packages=(
        aircrack-ng nmap nmap-common bluelog blueranger spooftooph
        pixiewps redfang nethunter-utils kali-nethunter-core sox
    )

    local all_bins=()
    for pkg in "${kali_packages[@]}"; do
        while IFS= read -r binpath; do
            [ -n "$binpath" ] && all_bins+=("$binpath")
        done < <(dpkg --admindir="${rootfs}/var/lib/dpkg" -L "$pkg" 2>/dev/null \
                 | grep -E "^/usr/(s?bin)/[^/]+$")
    done

    for binpath in "${all_bins[@]}"; do
        local name=$(basename "$binpath")

        # Skip if already exists in Termux and NOT our wrapper
        if [ -f "${wrapper_dir}/${name}" ]; then
            if ! grep -q "KALI_WRAPPER" "${wrapper_dir}/${name}" 2>/dev/null; then
                continue
            fi
        fi

        # Create wrapper
        cat > "${wrapper_dir}/${name}" << WEOF
#!/data/data/com.termux/files/usr/bin/bash
# KALI_WRAPPER — auto-generated by install-kali
exec proot-distro login kali --user root -- ${binpath} "\$@" 2> >(grep -v "^proot warning" >&2)
WEOF
        chmod 755 "${wrapper_dir}/${name}"
        echo "$name" >> "$manifest"
        count=$((count + 1))
    done

    ok "${count} tool wrappers created (aircrack-ng, nmap, bluelog, ...)"
    msg "Run any Kali tool directly: e.g. 'aircrack-ng --help'"
}

do_remove() {
    msg "Removing Kali from proot-distro..."

    # Remove tool wrappers first
    local manifest="${ROOTFS_DIR}/${KALI_ALIAS}/.kali-wrappers"
    if [ -f "$manifest" ]; then
        local wcount=0
        while IFS= read -r wrapper_name; do
            rm -f "${PREFIX}/bin/${wrapper_name}" 2>/dev/null
            wcount=$((wcount + 1))
        done < "$manifest"
        msg "Removed ${wcount} tool wrappers"
    fi

    if [ -d "${ROOTFS_DIR}/${KALI_ALIAS}" ]; then
        proot-distro remove "${KALI_ALIAS}" 2>/dev/null || {
            chmod -R u+rwx "${ROOTFS_DIR}/${KALI_ALIAS}" 2>/dev/null || true
            rm -rf "${ROOTFS_DIR}/${KALI_ALIAS}"
        }
    fi

    rm -f "${PLUGIN_DIR}/${KALI_ALIAS}.sh"
    rm -f "${PREFIX}/bin/nethunter" "${PREFIX}/bin/nh"

    # Remove symlink if exists
    [ -L "${HOME}/kali-arm64" ] && rm -f "${HOME}/kali-arm64"

    ok "Kali removed"
}

print_usage() {
    msg "Usage:"
    printf "  nethunter             # Login as kali user\n"
    printf "  nethunter -r          # Login as root\n"
    printf "  nethunter kex passwd  # Set KeX password\n"
    printf "  nethunter kex start   # Start KeX GUI\n"
    printf "  nh                    # Shortcut for nethunter\n"
    printf "  nh -r                 # Shortcut for root\n"
    printf "\n"
    printf "  ${green}Kali tools work directly from Termux:${reset}\n"
    printf "  aircrack-ng, nmap, airodump-ng, bluelog, ...\n"
}

# ─── Main ───────────────────────────────────────────────────────────────

print_banner
get_arch

MODE="download"
VARIANT="nano"

while [ $# -gt 0 ]; do
    case "$1" in
        --local)   MODE="local" ;;
        --full)    VARIANT="full" ;;
        --minimal) VARIANT="minimal" ;;
        --nano)    VARIANT="nano" ;;
        --remove)  MODE="remove" ;;
        -h|--help)
            echo "Usage: install-kali [--local|--full|--minimal|--nano|--remove]"
            exit 0
            ;;
        *) err "Unknown option: $1" ;;
    esac
    shift
done

case "$MODE" in
    remove)
        do_remove
        exit 0
        ;;
    local)
        check_deps
        create_plugin "$VARIANT"
        install_local
        create_shortcuts
        create_tool_wrappers
        ;;
    download)
        check_deps
        create_plugin "$VARIANT"
        install_download "$VARIANT"
        create_shortcuts
        create_tool_wrappers
        ;;
esac

printf "\n"
ok "Kali Linux ready!"
printf "\n"
print_usage
printf "\n"
